// Schema do Thymeria Gwent — Fase 1.7
// Tabelas: User, Faction, Ability, Card

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String?
  role          String   @default("PLAYER") // "PLAYER" ou "ADMIN"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// FACÇÕES (gerenciadas pelo admin)
// ─────────────────────────────────────────────
model Faction {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#c9a961") // cor temática (hex) para UI
  description String?  // lore/sabor opcional
  isActive    Boolean  @default(true)      // admin pode desativar sem perder dados
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards       Card[]
}

// ─────────────────────────────────────────────
// HABILIDADES (gerenciadas pelo admin)
// ─────────────────────────────────────────────
// Se engineKey estiver preenchido com um valor conhecido pelo motor
// (BOOST, DAMAGE, SPAWN, BOND, SPY, DRAW...), o motor da Fase 4
// executa o efeito automaticamente. Caso contrário, o efeito é
// apenas descritivo e o GM resolve narrativamente.
model Ability {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   // texto exibido na carta
  engineKey   String?  // BOOST | DAMAGE | SPAWN | BOND | SPY | DRAW | null
  engineValue Int?     // parâmetro numérico (ex: BOOST 3 = +3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards       Card[]
}

// ─────────────────────────────────────────────
// CARTAS (catálogo mestre)
// ─────────────────────────────────────────────
model Card {
  id          String   @id @default(cuid())
  name        String   @unique
  power       Int
  rows        String   // CSV de fileiras: "MELEE", "RANGED", "SIEGE"
  rarity      String   @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  cardType    String   @default("UNIT")   // UNIT, SPECIAL, LEADER
  loreText    String?
  imageUrl    String?
  isReleased  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  factionId   String
  faction     Faction  @relation(fields: [factionId], references: [id])

  abilityId   String?
  ability     Ability? @relation(fields: [abilityId], references: [id])

  sellPriceOverride   Int?   // se preenchido, sobrescreve o padrão por raridade
  maxPerDeckOverride  Int?   // idem

}

// ─────────────────────────────────────────────
// CONFIGURAÇÕES GLOBAIS (singleton)
// ─────────────────────────────────────────────
// Sempre exatamente 1 linha (id fixo = "singleton").
// Define padrões por raridade pra venda e limite de cópias.
model GameSettings {
  id        String   @id @default("singleton")

  // Preços de venda padrão (moedas) por raridade
  sellPriceCommon    Int @default(5)
  sellPriceRare      Int @default(20)
  sellPriceEpic      Int @default(60)
  sellPriceLegendary Int @default(150)

  // Limites de cópias no deck por raridade
  maxPerDeckCommon    Int @default(3)
  maxPerDeckRare      Int @default(2)
  maxPerDeckEpic      Int @default(1)
  maxPerDeckLegendary Int @default(1)

  // Política de venda
  allowSellLastCopy Boolean @default(false)

  updatedAt DateTime @updatedAt
}