// Schema do Thymeria Gwent — Fase 2.1
// Tabelas: User, Faction, Ability, Card, GameSettings,
//          UserCollection, Booster, BoosterRule,
//          Transaction, BoosterOpening, BoosterOpeningResult

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String?
  role          String   @default("PLAYER")
  coins         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  collection    UserCollection[]
  transactions  Transaction[]
  openings      BoosterOpening[]
  unopened      UnopenedBooster[]
  pity          UserPity[]
  decks         Deck[]
  matchPlayers  MatchPlayer[]

}

// ─────────────────────────────────────────────
// FACÇÕES
// ─────────────────────────────────────────────
model Faction {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#c9a961")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards       Card[]
  decks       Deck[]
}

// ─────────────────────────────────────────────
// HABILIDADES
// ─────────────────────────────────────────────
model Ability {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  engineKey   String?
  engineValue Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards       Card[]
}

// ─────────────────────────────────────────────
// CARTAS
// ─────────────────────────────────────────────
model Card {
  id          String   @id @default(cuid())
  name        String   @unique
  power       Int
  rows        String
  rarity      String   @default("COMMON")
  cardType    String   @default("UNIT")
  leaderMode  String?  // ACTIVE | PERSISTENT | PASSIVE (apenas para cartas LEADER)
  loreText    String?
  imageUrl    String?
  isReleased  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  factionId   String
  faction     Faction  @relation(fields: [factionId], references: [id])

  abilityId   String?
  ability     Ability? @relation(fields: [abilityId], references: [id])

  sellPriceOverride   Int?
  maxPerDeckOverride  Int?

  collectedBy        UserCollection[]
  boosterFixedRules  BoosterRule[]    @relation("FixedPool")
  openingResults     BoosterOpeningResult[]
  inDecksAsLeader    DeckLeader[]
  inDecks            DeckCard[]
  inHands       MatchHand[]
  onBoard       MatchBoardCard[]
  weatherCard   MatchWeather[]
}

// ─────────────────────────────────────────────
// CONFIGURAÇÕES GLOBAIS (singleton)
// ─────────────────────────────────────────────
model GameSettings {
  id        String   @id @default("singleton")

  sellPriceCommon    Int @default(5)
  sellPriceRare      Int @default(20)
  sellPriceEpic      Int @default(60)
  sellPriceLegendary Int @default(150)

  maxPerDeckCommon    Int @default(3)
  maxPerDeckRare      Int @default(2)
  maxPerDeckEpic      Int @default(1)
  maxPerDeckLegendary Int @default(1)

  allowSellLastCopy Boolean @default(false)

  pityThresholdCommon    Int @default(3)
  pityThresholdRare      Int @default(5)
  pityThresholdEpic      Int @default(3)
  pityThresholdLegendary Int @default(2)

  maxDecksPerPlayer   Int @default(5)
  minCardsPerDeck     Int @default(20)
  maxCardsPerDeck     Int @default(30)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COLEÇÃO DE CARTAS (por usuário)
// ─────────────────────────────────────────────
model UserCollection {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// BOOSTERS
// ─────────────────────────────────────────────
model Booster {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Int
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules    BoosterRule[]
  openings BoosterOpening[]
  unopened UnopenedBooster[]
}

model BoosterRule {
  id        String  @id @default(cuid())
  boosterId String
  mode      String  // "FIXED_POOL" | "BY_RARITY"
  rarity    String?
  cardId    String?
  quantity  Int     @default(1)

  booster Booster @relation(fields: [boosterId], references: [id], onDelete: Cascade)
  card    Card?   @relation("FixedPool", fields: [cardId], references: [id], onDelete: Cascade)

  @@index([boosterId])
}

// ─────────────────────────────────────────────
// HISTÓRICO DE MOEDA
// ─────────────────────────────────────────────
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String   // ADMIN_GRANT | BOOSTER_PURCHASE | CARD_SELL | MATCH_REWARD | OTHER
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// HISTÓRICO DE ABERTURAS
// ─────────────────────────────────────────────
model BoosterOpening {
  id        String   @id @default(cuid())
  userId    String
  boosterId String
  pricePaid Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  booster Booster @relation(fields: [boosterId], references: [id], onDelete: Restrict)
  results BoosterOpeningResult[]

  @@index([userId])
  @@index([createdAt])
}

model BoosterOpeningResult {
  id        String   @id @default(cuid())
  openingId String
  cardId    String
  wasNew    Boolean

  opening BoosterOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  card    Card           @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@index([openingId])
}

// ─────────────────────────────────────────────
// ESTANTE DE BOOSTERS FECHADOS
// ─────────────────────────────────────────────
// Cada linha = 1 booster fechado no inventário do jogador.
// Comprar cria. Abrir deleta e gera BoosterOpening + Results.
model UnopenedBooster {
  id          String   @id @default(cuid())
  userId      String
  boosterId   String
  pricePaid   Int      // snapshot do preço pago
  acquiredAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  booster Booster @relation(fields: [boosterId], references: [id], onDelete: Restrict)

  @@index([userId])
}

// ─────────────────────────────────────────────
// PITY SYSTEM (por jogador + raridade)
// ─────────────────────────────────────────────
model UserPity {
  id        String   @id @default(cuid())
  userId    String
  rarity    String   // COMMON | RARE | EPIC | LEGENDARY
  counter   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rarity])
  @@index([userId])
}

// ─────────────────────────────────────────────
// DECKS DOS JOGADORES
// ─────────────────────────────────────────────
model Deck {
  id        String   @id @default(cuid())
  userId    String
  factionId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id])

  leader  DeckLeader?
  cards   DeckCard[]
  matchPlayers MatchPlayer[]

  @@index([userId])
}

// Líder do deck (1:1 com Deck). Tabela separada pra permitir trocar
// o líder sem recriar o deck e pra garantir unicidade.
model DeckLeader {
  id     String @id @default(cuid())
  deckId String @unique
  cardId String

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])
}

// Cartas no deck. Cada linha = 1 cópia. Se o jogador quer 3 cópias
// da mesma carta, são 3 linhas. Mais simples pra contar/validar.
model DeckCard {
  id     String @id @default(cuid())
  deckId String
  cardId String

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@index([deckId])
  @@index([cardId])
}

// ─────────────────────────────────────────────
// PARTIDAS
// ─────────────────────────────────────────────

// status: SETUP | REDRAW | PLAYING | FINISHED
// mode: HOTSEAT (Fase 4) | ONLINE (Fase 5)
model Match {
  id              String   @id @default(cuid())
  mode            String   @default("HOTSEAT")
  status          String   @default("SETUP")
  currentRound    Int      @default(1)        // 1, 2 ou 3
  currentTurnSide String?  // "A" ou "B" — qual lado está jogando agora
  winnerSide      String?  // "A", "B", "DRAW" ou null se ainda não terminou
  startsRoundSide String?  // quem começa a próxima ronda
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  finishedAt      DateTime?

  players  MatchPlayer[]
  hands    MatchHand[]
  board    MatchBoardCard[]
  weather  MatchWeather[]
  events   MatchEvent[]

  @@index([status])
}

// Cada partida tem exatamente 2 MatchPlayer (lado A e lado B).
model MatchPlayer {
  id              String   @id @default(cuid())
  matchId         String
  side            String   // "A" ou "B"
  userId          String
  deckId          String
  roundsWon       Int      @default(0)
  hasPassed       Boolean  @default(false)   // passou na ronda atual?
  leaderUsed      Boolean  @default(false)   // já usou habilidade do líder?
  redrawsLeft     Int      @default(3)       // recomeça a cada ronda (3/2/1)
  deckCardCount   Int      @default(0)       // quantas cartas restam no deck (não-jogadas)

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id])
  deck    Deck  @relation(fields: [deckId], references: [id])

  @@unique([matchId, side])
  @@index([matchId])
}

// Cartas embaralhadas e disponíveis: tanto as que estão na mão quanto
// as que ainda estão no deck (zone).
// zone: DECK | HAND | DISCARD
model MatchHand {
  id        String   @id @default(cuid())
  matchId   String
  side      String   // "A" ou "B"
  cardId    String
  zone      String   @default("DECK")
  deckOrder Int      // posição original no embaralhamento (pra compras determinísticas)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  card  Card  @relation(fields: [cardId], references: [id])

  @@index([matchId, side, zone])
}

// Cartas que estão no tabuleiro (uma por unidade jogada).
// power: poder atual (já com modificadores)
// basePower: poder original
// row: MELEE | RANGED | SIEGE
// shielded: true se tem shield ativo
// isToken: true se foi gerada por SPAWN (não vai pro descarte do dono)
model MatchBoardCard {
  id           String   @id @default(cuid())
  matchId      String
  side         String   // dono atual da carta na mesa (pode ter virado por SPY)
  cardId       String
  row          String   // MELEE | RANGED | SIEGE
  basePower    Int
  power        Int
  shielded     Boolean  @default(false)
  isToken      Boolean  @default(false)
  playedAt     DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  card  Card  @relation(fields: [cardId], references: [id])

  @@index([matchId, side, row])
}

// Climas ativos por fileira.
// weatherKey: WEATHER_RAIN | WEATHER_FROST | WEATHER_FOG | WEATHER_STORM
// affectedRow: MELEE | RANGED | SIEGE
model MatchWeather {
  id           String   @id @default(cuid())
  matchId      String
  weatherKey   String
  affectedRow  String
  cardId       String   // carta de clima que ativou (pra referência)
  appliedAt    DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  card  Card  @relation(fields: [cardId], references: [id])

  @@index([matchId])
}

// Log de eventos da partida (auditoria / replay).
// type: REDRAW | PLAY_CARD | PASS | WEATHER | LEADER_ABILITY |
//       ROUND_END | MATCH_END | DAMAGE | BOOST | etc.
// payload: JSON serializado com detalhes
model MatchEvent {
  id        String   @id @default(cuid())
  matchId   String
  round     Int
  side      String?
  type      String
  payload   String   // JSON
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([matchId, round])
}